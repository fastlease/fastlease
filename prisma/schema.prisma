// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// Funnel surface: every estimate request and call booking lands here.
// One row per submission. Estimate snapshot stored so future analytics can
// reconcile what the model said vs. what actually leased.
model Lead {
    id            String   @id @default(cuid())
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    kind          LeadKind @default(ESTIMATE)
    source        String?  // "form" | "rent-widget" | "exit-intent" | "tenants" | "neighborhood:king-west" | ...

    // Contact
    email         String
    name          String?
    phone         String?

    // Unit
    neighborhood  String
    bedrooms      String
    targetRent    Int?
    address       String?
    moveWindow    String?  // "urgent" | "soon" | "flexible"

    // Snapshot of the estimate the user saw at submission time
    estDays       Int?
    estRentLow    Int?
    estRentHigh   Int?
    estListDate   String?
    estLeaseBy    String?

    // Call-specific
    timeWindow    String?

    // Attribution
    referralCode  String?
    referrer      Referral? @relation(fields: [referralCode], references: [code])
    utmSource     String?
    utmMedium     String?
    utmCampaign   String?
    landingPath   String?

    @@index([createdAt])
    @@index([email])
    @@index([neighborhood])
}

enum LeadKind {
    ESTIMATE
    CALL
    TENANT_SHORTLIST
}

// Referral codes: $200 off the fee for the landlord who sent the lead.
// One row per landlord; uses count + lastUsedAt to track viral reach.
model Referral {
    code        String   @id
    ownerEmail  String
    ownerName   String?
    createdAt   DateTime @default(now())
    lastUsedAt  DateTime?
    uses        Int      @default(0)
    leads       Lead[]

    @@index([ownerEmail])
}
